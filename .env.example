# tomat deploy/release environment.
#
# Copy this to `.env` (gitignored) and fill in. The deploy script
# (`deno task website:deploy`) reads from `.env`; missing keypairs are
# generated and written back on first run.

# --- Cloudflare auth -------------------------------------------------------
# The deploy script uses `wrangler` for both R2 uploads and Worker deploys.
# Run `wrangler login` once (interactive OAuth, persists in
# ~/.config/.wrangler/) and leave the variables below empty. They're here
# only if you ever want to switch to a non-interactive token; in that case,
# fill them both and uncomment the line in scripts/website/deploy.ts that
# exports them into the wrangler invocation environment.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Manifest signing (auto-generated) -------------------------------------
# Ed25519 keypair, base64-standard-encoded raw bytes (32 bytes each).
# The deploy script generates these on first run if both are empty, and
# writes the public half into packages/tomat-core/src/signing-keys.ts so
# every compiled core binary trusts the matching signatures.
#
# - PRIVATE key never leaves this file. Treat it like any other secret;
#   losing it means you must rotate the public key in signing-keys.ts AND
#   re-sign every published manifest.
# - PUBLIC key is committed via signing-keys.ts. Safe to share.
TOMAT_SIGNING_PRIVATE_KEY_B64=
TOMAT_SIGNING_PUBLIC_KEY_B64=

# --- Domains ---------------------------------------------------------------
# Override only if you're forking and pointing at a different CDN.
# These must match `CDN_BASE_URL` / `RELEASES_BASE_URL` in
# packages/tomat-core/src/config.ts.
TOMAT_CDN_DOMAIN=au.tomat.ing
TOMAT_RELEASES_DOMAIN=get.au.tomat.ing

# --- R2 bucket -------------------------------------------------------------
# Set up once per Cloudflare account; see packages/tomat-website/README.md.
TOMAT_R2_BUCKET=tomat-releases
