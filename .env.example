# tomat release environment.
#
# Copy this to `.env` (gitignored) and fill in. The release scripts read from
# `.env`; missing keypairs are generated and written back on first run.

# --- Cloudflare auth -------------------------------------------------------
# The release scripts use `wrangler` for both R2 uploads (R2 release artifacts)
# and the landing-page Worker deploy (both part of `deno task release`). When set
# below, the scripts hand these to wrangler for non-interactive auth; leave both
# empty to fall back to a stored `wrangler login` OAuth session (interactive,
# persists in ~/.config/.wrangler/).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Manifest signing (auto-generated) -------------------------------------
# Ed25519 keypair, base64-standard-encoded raw bytes (32 bytes each).
# The release:core / release:client scripts generate these on first run if
# both are empty, and write the public half into
# packages/tomat-core/data/signing-keys.json so every compiled core binary
# trusts the matching signatures.
#
# - PRIVATE key never leaves this file. Treat it like any other secret;
#   losing it means you must rotate the public key in signing-keys.json AND
#   re-sign every published manifest.
# - PUBLIC key is committed via signing-keys.json. Safe to share.
TOMAT_SIGNING_PRIVATE_KEY_B64=
TOMAT_SIGNING_PUBLIC_KEY_B64=

# --- Tauri client updater keypair ------------------------------------------
# tauri-plugin-updater uses its own minisign-style keypair (not the Ed25519
# pair above). Generate with `cargo tauri signer generate` and paste the
# outputs below. The private key is the multi-line text block; the
# password is what you typed when generating it (empty for no password).
#
# release:client substitutes the public half into
# packages/tomat-client/src/tauri/tauri.conf.json before the client build,
# then signs the produced bundles with the private half (via the
# TAURI_SIGNING_PRIVATE_KEY env var the build pipeline reads).
TAURI_UPDATER_PUBLIC_KEY=
TAURI_UPDATER_PRIVATE_KEY=
TAURI_UPDATER_PRIVATE_KEY_PASSWORD=

# --- Android release keystore ----------------------------------------------
# Signs the release APK (release:android). Android verifies the APK signature on
# install/update, so this is the real trust gate for self-hosted mobile updates;
# the Ed25519 key above also signs android.json. Generate once with keytool:
#   keytool -genkey -v -keystore tomat-release.jks -keyalg RSA -keysize 2048 \
#     -validity 10000 -alias upload
# then base64 the .jks into TOMAT_ANDROID_KEYSTORE_B64 (e.g. `base64 -i
# tomat-release.jks`). Leave blank to skip the android item in a release run.
TOMAT_ANDROID_KEYSTORE_B64=
TOMAT_ANDROID_KEYSTORE_PASSWORD=
TOMAT_ANDROID_KEY_ALIAS=upload
TOMAT_ANDROID_KEY_PASSWORD=

# --- Apple signing (macOS + iOS, optional) ---------------------------------
# Covers BOTH the macOS client bundle (Developer ID signing + notarization) and
# the iOS build (App Store Connect signing + upload). ALL OPTIONAL: leave
# everything blank and the macOS build keeps ad-hoc signing (tauri.conf.json's
# signingIdentity "-") and skips notarization while the iOS build/release is
# skipped entirely (an unsigned Simulator build is still possible locally) -
# exactly today's behavior. Fill these once an Apple Developer account +
# certificate are in hand; see the step-by-step at
# scripts/release/macos-signing.md. Apple can't be cross-signed, so these are
# read only on a macOS host/runner. The App Store Connect API-key trio
# (APPLE_API_*) is what the iOS .ipa upload uses.
#
# Signing identity: the certificate's common name, e.g.
#   "Developer ID Application: Your Name (TEAMID1234)". Locally you can leave
# APPLE_CERTIFICATE/APPLE_CERTIFICATE_PASSWORD blank and rely on the cert already
# in your login keychain; on CI, export the cert as a base64 .p12 into
# APPLE_CERTIFICATE (+ its password) so the runner can import it.
APPLE_SIGNING_IDENTITY=
APPLE_CERTIFICATE=
APPLE_CERTIFICATE_PASSWORD=
#
# Notarization credentials - fill EITHER the Apple ID trio OR the App Store
# Connect API-key trio (not both). APPLE_PASSWORD is an app-specific password
# (appleid.apple.com), not your Apple ID login password.
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
# ...or the App Store Connect API key (APPLE_API_KEY_PATH points at the .p8):
APPLE_API_KEY=
APPLE_API_ISSUER=
APPLE_API_KEY_PATH=

# --- Windows Authenticode (optional, DORMANT) ------------------------------
# Empty by default (no cert yet): the client + Core NSIS installers ship
# unsigned and the install flow strips Mark-of-the-Web. Fill the thumbprint of
# a cert in the runner's store (or a full sign command with %1 for the file, e.g.
# an Azure Trusted Signing dlib invocation) to Authenticode-sign the installers.
WINDOWS_CERTIFICATE_THUMBPRINT=
WINDOWS_SIGN_COMMAND=
WINDOWS_TIMESTAMP_URL=

# --- Domains ---------------------------------------------------------------
# Override only if you're forking and pointing at different hostnames.
# These must match `WEBSITE_BASE_URL` / `STORAGE_BASE_URL` in
# packages/tomat-core/src/config.ts.
TOMAT_WEBSITE_DOMAIN=au.tomat.ing
TOMAT_STORAGE_DOMAIN=get.au.tomat.ing

# --- R2 bucket -------------------------------------------------------------
# Set up once per Cloudflare account; see packages/tomat-website/README.md.
TOMAT_R2_BUCKET=tomat-releases

# --- GitHub release automation (optional) ----------------------------------
# Used by scripts/release/core.ts when resolving upstream sidecar binaries
# (llama-server, whisper-server, deno) to raise the GitHub API rate limit.
# A fine-grained token with public-repo read access is enough.
GITHUB_TOKEN=

# --- Cross-platform build drivers ------------------------------------------
# Device-specific config for the on-demand build environments a cross-platform
# `deno task release` / `deno task build` uses (host-only runs ignore these):
# the Podman Linux container (scripts/release/drivers/podman.ts) and the UTM
# Windows VM (scripts/release/drivers/windows.ts). All local to your machine, so
# they live here rather than in the committed drivers. A driver stays disabled
# (skipped) until its required keys below are filled.

# Podman Linux driver. TOMAT_PODMAN_MACHINE is required to enable it
# (`podman machine list` -> the NAME column). The image tag is built from
# scripts/release/drivers/linux/Containerfile.
TOMAT_PODMAN_MACHINE=
TOMAT_LINUX_BUILD_IMAGE=tomat-linux-build:latest

# Windows UTM driver. VM name + SSH host + SSH user are required to enable it.
# TOMAT_WIN_VM_NAME: `utmctl list` -> the VM name (or its UUID).
# TOMAT_WIN_SSH_HOST: the guest's LAN address once booted (bridged DHCP, so pin a
#   reservation or use the guest hostname if it moves across reboots).
# TOMAT_WIN_SSH_USER: the Windows account name.
# TOMAT_WIN_GUEST_REPO: where the repo is synced inside the guest.
# TOMAT_WIN_UTMCTL / TOMAT_WIN_VCVARSALL: adjust only if UTM or VS Build Tools
#   are installed somewhere other than the defaults shown.
TOMAT_WIN_VM_NAME=
TOMAT_WIN_SSH_HOST=
TOMAT_WIN_SSH_USER=
TOMAT_WIN_SSH_PORT=22
TOMAT_WIN_SSH_IDENTITY_FILE=
TOMAT_WIN_GUEST_REPO=C:\work
TOMAT_WIN_UTMCTL=/Applications/UTM.app/Contents/MacOS/utmctl
TOMAT_WIN_VCVARSALL="C:\Program Files (x86)\Microsoft Visual Studio\2022\BuildTools\VC\Auxiliary\Build\vcvarsall.bat"
