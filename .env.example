# tomat deploy/release environment.
#
# Copy this to `.env` (gitignored) and fill in. The deploy script
# (`deno task website:deploy`) reads from `.env`; missing keypairs are
# generated and written back on first run.

# --- Cloudflare auth -------------------------------------------------------
# The deploy script uses `wrangler` for both R2 uploads and Worker deploys.
# Run `wrangler login` once (interactive OAuth, persists in
# ~/.config/.wrangler/) and leave the variables below empty. They're here
# only if you ever want to switch to a non-interactive token; in that case,
# fill them both and uncomment the line in scripts/website/deploy.ts that
# exports them into the wrangler invocation environment.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Manifest signing (auto-generated) -------------------------------------
# Ed25519 keypair, base64-standard-encoded raw bytes (32 bytes each).
# The deploy script generates these on first run if both are empty, and
# writes the public half into packages/tomat-core/data/signing-keys.json
# so every compiled core binary trusts the matching signatures.
#
# - PRIVATE key never leaves this file. Treat it like any other secret;
#   losing it means you must rotate the public key in signing-keys.json AND
#   re-sign every published manifest.
# - PUBLIC key is committed via signing-keys.json. Safe to share.
TOMAT_SIGNING_PRIVATE_KEY_B64=
TOMAT_SIGNING_PUBLIC_KEY_B64=

# --- Tauri client updater keypair ------------------------------------------
# tauri-plugin-updater uses its own minisign-style keypair (not the Ed25519
# pair above). Generate with `cargo tauri signer generate` and paste the
# outputs below — the private key is the multi-line text that block;
# password is what you typed when generating it (empty for no password).
#
# The deploy script substitutes the public half into
# packages/tomat-client/src/tauri/tauri.conf.json before the client build,
# then signs the produced bundles with the private half (via the
# TAURI_SIGNING_PRIVATE_KEY env var the build pipeline reads).
TAURI_UPDATER_PUBLIC_KEY=
TAURI_UPDATER_PRIVATE_KEY=
TAURI_UPDATER_PRIVATE_KEY_PASSWORD=

# --- Domains ---------------------------------------------------------------
# Override only if you're forking and pointing at a different CDN.
# These must match `CDN_BASE_URL` / `RELEASES_BASE_URL` in
# packages/tomat-core/src/config.ts. (The constants in config.ts derive
# their hostnames from these env vars at build time — keep both ends
# pointing at the same domain when forking.)
TOMAT_CDN_DOMAIN=au.tomat.ing
TOMAT_RELEASES_DOMAIN=get.au.tomat.ing

# --- R2 bucket -------------------------------------------------------------
# Set up once per Cloudflare account; see packages/tomat-website/README.md.
TOMAT_R2_BUCKET=tomat-releases

# --- GitHub release automation (optional) ----------------------------------
# Used by scripts/website/deploy.ts (~line 621) to create a GitHub Release
# alongside the manifest publish. Leave blank to skip the release step;
# wrangler-only deploys work without it. A fine-grained token scoped to
# the tomat repo with `contents:write` is enough.
GITHUB_TOKEN=
