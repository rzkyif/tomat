{
  "workspace": [
    "./packages/tomat-shared",
    "./packages/tomat-core",
    "./packages/tomat-client",
    "./packages/tomat-website",
    "./packages/tomat-builtin",
    "./packages/tomat-model-catalog",
    "./packages/tomat-core-updater",
    "./packages/tomat-core-keychain",
    "./packages/tomat-core-hwinfo",
    "./packages/tomat-core-ptyhost",
    "./packages/tomat-core-speech"
  ],
  "nodeModulesDir": "auto",
  "unstable": ["raw-imports"],
  "imports": {
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "@std/encoding": "jsr:@std/encoding@^1.0.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225",
    "@std/tar": "jsr:@std/tar@^0.1.0",
    "@noble/ed25519": "jsr:@noble/ed25519@^3.0.0"
  },
  "tasks": {
    "dev": "deno run -A --unsafely-ignore-certificate-errors=127.0.0.1 scripts/dev.ts",
    "dev:android": "deno run -A --unsafely-ignore-certificate-errors=127.0.0.1 scripts/dev.ts --android",
    "dev:reset": "deno run -A --unsafely-ignore-certificate-errors=127.0.0.1 scripts/dev.ts --reset",
    "dev:reset:install": "deno run -A --unsafely-ignore-certificate-errors=127.0.0.1 scripts/dev.ts --reset --fresh-install",
    "dev:core": "deno task --cwd packages/tomat-core dev",
    "dev:client": "deno task --cwd packages/tomat-client dev",
    "dev:client:android": "deno run -A --unsafely-ignore-certificate-errors=127.0.0.1 scripts/dev.ts --android --client-only",
    "dev:website": "deno task --cwd packages/tomat-website dev",

    "check": "deno run -A scripts/pkg.ts check && deno run -A scripts/check.ts",
    "lint": "deno run -A npm:oxlint@1.66.0 -c .oxlintrc.json . && deno run -A --quiet scripts/lint-plugins/check-tauri-imports-svelte.ts && deno run -A --quiet scripts/lint-plugins/check-em-dash.ts && deno run -A --quiet scripts/lint-plugins/check-uppercase-tomat.ts && deno run -A --quiet scripts/lint-plugins/check-builtin-palette-color.ts && deno run -A --quiet scripts/lint-plugins/check-shared-ui-purity.ts && deno run -A --quiet scripts/lint-plugins/check-view-coverage.ts && deno run -A --quiet scripts/lint-plugins/check-component-tiers.ts && deno run -A --quiet scripts/lint-plugins/check-website-composer.ts && deno run -A --quiet scripts/lint-plugins/check-icon-classes.ts && deno run -A scripts/pkg.ts lint",
    "fmt": "deno run -A npm:oxfmt@0.51.0 . && deno run -A scripts/pkg.ts fmt",
    "fmt:check": "deno run -A npm:oxfmt@0.51.0 --check . && deno run -A scripts/pkg.ts fmt:check",
    "test": "deno run -A scripts/pkg.ts test",
    "test:e2e": "deno run -A scripts/test-e2e.ts",
    "test:e2e:headless": "deno run -A scripts/test-e2e-headless.ts",

    "check:shared": "deno task --cwd packages/tomat-shared check",
    "check:core": "deno task --cwd packages/tomat-core check",
    "check:client": "deno task --cwd packages/tomat-client check",
    "check:extension": "deno task --cwd packages/tomat-builtin check",
    "check:catalog": "deno task --cwd packages/tomat-model-catalog check",
    "check:core-updater": "deno task --cwd packages/tomat-core-updater check",
    "check:core-keychain": "deno task --cwd packages/tomat-core-keychain check",
    "check:core-hwinfo": "deno task --cwd packages/tomat-core-hwinfo check",
    "check:core-ptyhost": "deno task --cwd packages/tomat-core-ptyhost check",
    "check:core-speech": "deno task --cwd packages/tomat-core-speech check",

    "test:shared": "deno task --cwd packages/tomat-shared test",
    "test:core": "deno task --cwd packages/tomat-core test",
    "test:client": "deno task --cwd packages/tomat-client test",
    "test:extension": "deno task --cwd packages/tomat-builtin test",
    "test:core-updater": "deno task --cwd packages/tomat-core-updater test",
    "test:core-keychain": "deno task --cwd packages/tomat-core-keychain test",
    "test:core-hwinfo": "deno task --cwd packages/tomat-core-hwinfo test",
    "test:core-ptyhost": "deno task --cwd packages/tomat-core-ptyhost test",
    "test:core-speech": "deno task --cwd packages/tomat-core-speech test",

    "fmt:client": "deno task --cwd packages/tomat-client fmt",
    "fmt:core-updater": "deno task --cwd packages/tomat-core-updater fmt",
    "fmt:core-keychain": "deno task --cwd packages/tomat-core-keychain fmt",
    "fmt:core-hwinfo": "deno task --cwd packages/tomat-core-hwinfo fmt",
    "fmt:core-ptyhost": "deno task --cwd packages/tomat-core-ptyhost fmt",
    "fmt:core-speech": "deno task --cwd packages/tomat-core-speech fmt",

    "lint:client": "deno task --cwd packages/tomat-client lint",
    "lint:core-updater": "deno task --cwd packages/tomat-core-updater lint",
    "lint:core-keychain": "deno task --cwd packages/tomat-core-keychain lint",
    "lint:core-hwinfo": "deno task --cwd packages/tomat-core-hwinfo lint",
    "lint:core-ptyhost": "deno task --cwd packages/tomat-core-ptyhost lint",
    "lint:core-speech": "deno task --cwd packages/tomat-core-speech lint",

    "build:core-updater": "deno task --cwd packages/tomat-core-updater build",
    "build:core-keychain": "deno task --cwd packages/tomat-core-keychain build",
    "build:core-hwinfo": "deno task --cwd packages/tomat-core-hwinfo build",
    "build:core-ptyhost": "deno task --cwd packages/tomat-core-ptyhost build",
    "build:core-speech": "deno task --cwd packages/tomat-core-speech build",

    "build": "deno run -A scripts/build.ts --channel=latest",
    "build:stable": "deno run -A scripts/build.ts --channel=stable",
    "build:core": "deno run -A scripts/build-core.ts --channel=latest",
    "build:core:stable": "deno run -A scripts/build-core.ts --channel=stable",
    "build:client": "deno run -A scripts/build-client.ts --channel=latest",
    "build:client:stable": "deno run -A scripts/build-client.ts --channel=stable",
    "build:client:android": "deno run -A scripts/build-android.ts --channel=latest",
    "build:client:android:stable": "deno run -A scripts/build-android.ts --channel=stable",
    "build:catalog": "deno run -A scripts/catalog/build.ts",
    "build:website": "deno run -A scripts/website/build.ts",
    "release": "deno run -A scripts/release/main.ts --channel=latest",
    "release:stable": "deno run -A scripts/release/main.ts --channel=stable",
    "clean": "deno run -A scripts/clean.ts"
  },
  "exclude": [
    "**/node_modules",
    "**/target",
    "**/build",
    "**/dist",
    "**/.svelte-kit",
    "**/.astro",
    "**/.wrangler",
    "**/.deno-cache",
    "tests/e2e"
  ],
  "allowScripts": [
    "npm:esbuild@0.21.5",
    "npm:esbuild@0.27.3",
    "npm:esbuild@0.27.7",
    "npm:fsevents@2.3.3",
    "npm:protobufjs@7.5.8",
    "npm:workerd@1.20260518.1"
  ]
}
