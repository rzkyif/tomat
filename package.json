{
  "name": "tomat",
  "version": "0.1.0",
  "description": "A local-first modular AI client",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "bun run build:bun && tauri dev",
    "dev:vite": "vite dev",
    "build": "tauri build",
    "build:vite": "bun run build:bun && vite build",
    "build:bun": "bun build src-bun/index.ts --outfile=src-tauri/resources/server.js --target=bun --minify --external onnxruntime-node --external onnxruntime-common --external kokoro-js --external @huggingface/transformers --external phonemizer",
    "preview": "vite preview",
    "check": "bun run check:js && bun run check:rs",
    "check:js": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && bun run lint:js && bun run format:js",
    "check:rs": "cargo check --manifest-path src-tauri/Cargo.toml --all-targets && bun run lint:rs && bun run format:rs",
    "tauri": "tauri",
    "fetch": "bun scripts/fetch-required-files.mjs",
    "lint": "bun run lint:js && bun run lint:rs",
    "lint:js": "oxlint . --fix",
    "lint:rs": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "format": "bun run format:js && bun run format:rs",
    "format:js": "oxfmt . --write",
    "format:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.9",
    "@huggingface/transformers": "^3.4.0",
    "@ricky0123/vad-web": "^0.0.30",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2.3.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "dompurify": "^3.3.3",
    "elysia": "^1.4.28",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "kokoro-js": "^1.2.1",
    "marked": "^18.0.0",
    "marked-highlight": "^2.2.4",
    "openai": "^6.33.0",
    "title-case": "^4.3.2"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.460",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2",
    "@types/bun": "^1.3.11",
    "@types/dompurify": "^3.0.5",
    "@unocss/extractor-svelte": "^66.6.8",
    "@unocss/preset-typography": "^66.6.8",
    "@unocss/reset": "^66.6.8",
    "fflate": "^0.8.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.58.0",
    "sass-embedded": "^1.99.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~6.0.2",
    "unocss": "^66.6.8",
    "vite": "^8.0.7"
  }
}
