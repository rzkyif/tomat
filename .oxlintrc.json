{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "ignorePatterns": ["**/.svelte-kit", "**/.astro", "**/.wrangler"],
  "jsPlugins": ["./scripts/lint-plugins/oxlint-plugin.ts"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "tomat/no-em-dash": "error",
    "tomat/no-uppercase-tomat": "error",
    "tomat/no-builtin-palette-color": "error"
  },
  "env": {
    "builtin": true
  },
  "overrides": [
    {
      "files": ["packages/tomat-client/src/ui/**/*.{ts,tsx}"],
      "rules": {
        "tomat/no-tauri-import": "error"
      }
    },
    {
      "files": ["packages/tomat-client/src/ui/lib/platform/*.ts"],
      "rules": {
        "tomat/no-tauri-import": "off"
      }
    },
    {
      "files": ["**/*.svelte"],
      "rules": {
        "tomat/no-uppercase-tomat": "off"
      }
    }
  ]
}
