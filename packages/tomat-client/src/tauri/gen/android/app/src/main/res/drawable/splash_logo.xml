        android:pivotX="256"
        android:pivotY="256"
        android:scaleX="0.66"
        android:scaleY="0.66">
        <path
            android:fillColor="@color/splash_logo"
            android:fillType="evenOdd"
            android:pathData="M256,48C370.798,48 464,141.202 464,256C464,370.798 370.798,464 256,464C141.202,464 48,370.798 48,256C48,141.202 141.202,48 256,48ZM256,100C169.901,100 100,169.901 100,256C100,342.099 169.901,204 256,204C342.099,204 412,342.099 412,256C412,169.901 342.099,100 256,100Z" />
    </group>
</vector>
