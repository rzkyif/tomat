<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.tomat" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
    </style>

    <!-- Launch splash (via androidx core-splashscreen, backported to our minSdk).
         Background and logo colors are DayNight color resources, so the splash is
         a dark surface + white logo in dark mode and a light surface + dark logo
         in light mode. No icon background color, so the logo sits directly on the
         surface. Hands off to Theme.tomat once the activity starts. -->
    <style name="Theme.tomat.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.tomat</item>
    </style>
</resources>
