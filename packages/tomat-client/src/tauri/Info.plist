<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS Info.plist keys Tauri merges into the desktop app bundle (and injects on
  `tauri dev`). These are the TCC purpose strings macOS requires before the app
  may touch the microphone or the local network; without them macOS denies the
  request (the microphone one silently kills voice input in a bundled build).
  Keep this macOS-only: iOS declares its own strings under gen/apple.
-->
<plist version="1.0">
  <dict>
    <key>NSMicrophoneUsageDescription</key>
    <string>tomat uses the microphone for voice input: push-to-talk and voice activity detection.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>tomat uses the local network to find and connect to a tomat Core running on another device.</string>
  </dict>
</plist>
