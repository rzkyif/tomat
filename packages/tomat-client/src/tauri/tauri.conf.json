{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tomat",
  "version": "0.1.0",
  "identifier": "au.tomat.ing",
  "build": {
    "beforeDevCommand": "deno task dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "deno task build:vite",
    "frontendDist": "../../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "tomat",
        "width": 700,
        "height": 1200,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "visible": false
      },
      {
        "label": "region-capture",
        "title": "Region Capture",
        "url": "/region-capture.html",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' http://127.0.0.1:* http://localhost:* https:; worker-src 'self' blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
