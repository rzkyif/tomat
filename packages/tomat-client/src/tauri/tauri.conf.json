{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tomat",
  "version": "0.1.0",
  "identifier": "au.tomat.ing",
  "build": {
    "beforeDevCommand": {
      "script": "deno task stage:vad && deno run -A npm:vite@^8 dev",
      "cwd": "../.."
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "script": "deno task stage:vad && deno run -A npm:vite@^8 build",
      "cwd": "../.."
    },
    "frontendDist": "../../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "tomat",
        "width": 700,
        "height": 1200,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "visible": false
      },
      {
        "label": "region-capture",
        "title": "Region Capture",
        "url": "/region-capture.html",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' http://127.0.0.1:* http://localhost:* https:; worker-src 'self' blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "appimage", "deb", "rpm", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://get.au.tomat.ing/manifests/client.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFREEyNUM0MjM2QUQyMEYKUldRUDBtb2p4Q1hhVHIvYTNVaG8zSDFYRFFLQlJpYmJuaStGdUtPcVA3V1J2ZVFZQjUvOTRaRmEK"
    }
  }
}
