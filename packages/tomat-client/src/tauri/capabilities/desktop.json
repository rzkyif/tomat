{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop-capability",
  "description": "Desktop-only permissions: the floating-window controls, file-manager reveal, global shortcut, in-app updater, process relaunch, autostart, and recursive fs access to ~/.tomat. These plugins are not registered on Android, so platform-scoping keeps the mobile build from requesting permissions for absent plugins.",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "global-shortcut:default",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-cursor-position",
    "core:window:allow-outer-position",
    "core:window:allow-outer-size",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-current-monitor",
    "opener:allow-reveal-item-in-dir",
    "updater:default",
    "process:default",
    "autostart:default",
    {
      "identifier": "fs:allow-home-read-recursive",
      "allow": [{ "path": "$HOME/.tomat/**" }]
    },
    {
      "identifier": "fs:allow-home-write-recursive",
      "allow": [{ "path": "$HOME/.tomat/**" }]
    },
    {
      "identifier": "fs:allow-home-meta-recursive",
      "allow": [{ "path": "$HOME/.tomat/**" }]
    }
  ]
}
