{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "paths": {
      "$lib": ["./src/ui/lib"],
      "$lib/*": ["./src/ui/lib/*"],
      "$app/types": ["./.svelte-kit/types/index.d.ts"],
      "@tomat/shared": ["../tomat-shared/src/index.ts"],
      "@tomat/shared/*": ["../tomat-shared/src/*"]
    }
  },
  // The SvelteKit-generated tsconfig sweeps in everything under src/ via
  // "src/**/*.{js,ts,svelte}". Exclude src/tauri (the Rust crate) and
  // node_modules.
  "exclude": ["src/tauri/**", "node_modules/**"]
}
