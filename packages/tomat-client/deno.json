{
  "name": "@tomat/client",
  "version": "0.1.0",
  "exports": {
    ".": "./src/ui/app.html"
  },
  "tasks": {
    "dev": "deno run -A npm:@tauri-apps/cli@^2 dev",
    "dev:vite": "deno run -A npm:vite@^8 dev",
    "build": "deno run -A npm:@tauri-apps/cli@^2 build",
    "build:vite": "deno run -A npm:vite@^8 build",
    "preview": "deno run -A npm:vite@^8 preview",
    "sync": "deno run -A npm:@sveltejs/kit@^2/svelte-kit sync",
    "check": "deno task sync && deno run -A npm:svelte-check@^4 --tsconfig ./tsconfig.json"
  },
  "imports": {
    "@tomat/shared": "../tomat-shared/src/index.ts",
    "@huggingface/transformers": "npm:@huggingface/transformers@^4.1.0",
    "@ricky0123/vad-web": "npm:@ricky0123/vad-web@^0.0.30",
    "@tauri-apps/api": "npm:@tauri-apps/api@^2.5.0",
    "@tauri-apps/api/core": "npm:@tauri-apps/api@^2.5.0/core",
    "@tauri-apps/api/event": "npm:@tauri-apps/api@^2.5.0/event",
    "@tauri-apps/plugin-dialog": "npm:@tauri-apps/plugin-dialog@^2.7.0",
    "@tauri-apps/plugin-fs": "npm:@tauri-apps/plugin-fs@^2.5.0",
    "@tauri-apps/plugin-global-shortcut": "npm:@tauri-apps/plugin-global-shortcut@^2.3.1",
    "@tauri-apps/plugin-opener": "npm:@tauri-apps/plugin-opener@^2.3.0",
    "@tauri-apps/plugin-process": "npm:@tauri-apps/plugin-process@^2",
    "@tauri-apps/plugin-shell": "npm:@tauri-apps/plugin-shell@^2.3.5",
    "@tauri-apps/plugin-updater": "npm:@tauri-apps/plugin-updater@^2",
    "countries-and-timezones": "npm:countries-and-timezones@^3.9.0",
    "dompurify": "npm:dompurify@^3.3.3",
    "fflate": "npm:fflate@^0.8.2",
    "github-markdown-css": "npm:github-markdown-css@^5.9.0",
    "highlight.js": "npm:highlight.js@^11.11.1",
    "lru-cache": "npm:lru-cache@^11.3.5",
    "marked": "npm:marked@^18.0.0",
    "marked-highlight": "npm:marked-highlight@^2.2.4",
    "title-case": "npm:title-case@^4.3.2",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@^3.0.6",
    "@sveltejs/kit": "npm:@sveltejs/kit@^2.9.0",
    "@sveltejs/kit/vite": "npm:@sveltejs/kit@^2.9.0/vite",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^7.0.0",
    "svelte": "npm:svelte@^5.0.0",
    "svelte/store": "npm:svelte@^5.0.0/store",
    "unocss": "npm:unocss@^66.6.8",
    "unocss/vite": "npm:unocss@^66.6.8/vite",
    "@unocss/extractor-svelte": "npm:@unocss/extractor-svelte@^66.6.8",
    "@unocss/preset-typography": "npm:@unocss/preset-typography@^66.6.8",
    "@unocss/reset": "npm:@unocss/reset@^66.6.8",
    "vite": "npm:vite@^8.0.7",
    "@iconify/json": "npm:@iconify/json@^2.2.460",
    "sass-embedded": "npm:sass-embedded@^1.99.0",
    "svelte-check": "npm:svelte-check@^4.0.0",
    "vitest": "npm:vitest@^3.2.0",
    "@vitest/coverage-v8": "npm:@vitest/coverage-v8@^3.2.0",
    "@testing-library/svelte": "npm:@testing-library/svelte@^5.2.0",
    "@testing-library/jest-dom": "npm:@testing-library/jest-dom@^6.6.0",
    "jsdom": "npm:jsdom@^25.0.0"
  }
}
