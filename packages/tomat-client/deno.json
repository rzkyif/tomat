{
  "name": "@tomat/client",
  "version": "0.1.0",
  "exports": {
    ".": "./src/ui/app.html"
  },
  "tasks": {
    "tauri": "deno run -A npm:@tauri-apps/cli@^2",
    "dev": "deno task tauri dev",
    "build": "deno task tauri build",
    "init:android": "deno task tauri android init",
    "dev:android": "deno task tauri android dev",
    "build:android": "deno task tauri android build --apk",
    "check:android": "cargo check --manifest-path src/tauri/Cargo.toml --target aarch64-linux-android",
    "init:ios": "deno task tauri ios init",
    "dev:ios": "deno task tauri ios dev",
    "build:ios": "deno task tauri ios build",
    "check:ios": "cargo check --manifest-path src/tauri/Cargo.toml --target aarch64-apple-ios",
    "stage:vad": "deno run -A scripts/stage-vad.ts",
    "sync": "deno run -A npm:@sveltejs/kit@^2/svelte-kit sync",
    "preview": "deno run -A npm:vite@^8 preview",
    "check": "deno task sync && deno run -A npm:svelte-check@^4 --tsconfig ./tsconfig.json",
    "lint": "cargo clippy --manifest-path src/tauri/Cargo.toml --all-targets -- -D warnings",
    "fmt": "cargo fmt --manifest-path src/tauri/Cargo.toml",
    "fmt:check": "cargo fmt --manifest-path src/tauri/Cargo.toml --check",
    "test:js": "deno run -A npm:vitest run",
    "test": "deno task test:js && cargo test --manifest-path src/tauri/Cargo.toml --lib"
  },
  "imports": {
    "@tomat/shared": "../tomat-shared/src/index.ts",
    "@ricky0123/vad-web": "npm:@ricky0123/vad-web@^0.0.30",
    "@tauri-apps/api": "npm:@tauri-apps/api@^2.11.0",
    "@tauri-apps/api/core": "npm:@tauri-apps/api@^2.11.0/core",
    "@tauri-apps/api/event": "npm:@tauri-apps/api@^2.11.0/event",
    "@tauri-apps/plugin-autostart": "npm:@tauri-apps/plugin-autostart@^2.5.1",
    "@tauri-apps/plugin-dialog": "npm:@tauri-apps/plugin-dialog@^2.7.1",
    "@tauri-apps/plugin-fs": "npm:@tauri-apps/plugin-fs@^2.5.1",
    "@tauri-apps/plugin-global-shortcut": "npm:@tauri-apps/plugin-global-shortcut@^2.3.2",
    "@tauri-apps/plugin-opener": "npm:@tauri-apps/plugin-opener@^2.5.4",
    "@tauri-apps/plugin-os": "npm:@tauri-apps/plugin-os@^2.3.1",
    "@tauri-apps/plugin-process": "npm:@tauri-apps/plugin-process@^2.3.1",
    "@tauri-apps/plugin-updater": "npm:@tauri-apps/plugin-updater@^2.10.1",
    "countries-and-timezones": "npm:countries-and-timezones@^3.9.0",
    "diff": "npm:diff@^8.0.2",
    "dompurify": "npm:dompurify@^3.4.8",
    "fflate": "npm:fflate@^0.8.3",
    "github-markdown-css": "npm:github-markdown-css@^5.9.0",
    "highlight.js": "npm:highlight.js@^11.11.1",
    "lru-cache": "npm:lru-cache@^11.5.1",
    "marked": "npm:marked@^18.0.5",
    "marked-highlight": "npm:marked-highlight@^2.2.4",
    "title-case": "npm:title-case@^4.3.2",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@^3.0.10",
    "@sveltejs/kit": "npm:@sveltejs/kit@^2.63.0",
    "@sveltejs/kit/vite": "npm:@sveltejs/kit@^2.63.0/vite",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^7.1.2",
    "svelte": "npm:svelte@^5.56.2",
    "svelte/store": "npm:svelte@^5.56.2/store",
    "unocss": "npm:unocss@^66.7.0",
    "unocss/vite": "npm:unocss@^66.7.0/vite",
    "@unocss/extractor-svelte": "npm:@unocss/extractor-svelte@^66.7.0",
    "@unocss/preset-typography": "npm:@unocss/preset-typography@^66.7.0",
    "@unocss/reset": "npm:@unocss/reset@^66.7.0",
    "vite": "npm:vite@^8.0.16",
    "@iconify/json": "npm:@iconify/json@^2.2.483",
    "sass-embedded": "npm:sass-embedded@^1.100.0",
    "svelte-check": "npm:svelte-check@^4.6.0",
    "@types/node": "npm:@types/node@^25.7.0",
    "vitest": "npm:vitest@^4.1.8",
    "@vitest/coverage-v8": "npm:@vitest/coverage-v8@^4.1.8",
    "@testing-library/svelte": "npm:@testing-library/svelte@^5.3.1",
    "@testing-library/jest-dom": "npm:@testing-library/jest-dom@^6.9.1",
    "jsdom": "npm:jsdom@^29.1.1"
  }
}
