{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://get.au.tomat.ing/schemas/tomat-v1.json",
  "version": "0.1.0",
  "title": "tomat.json",
  "description": "Manifest for a tomat extension: the tools it lets an LLM host execute and the knowledge/skills it bundles. Place at the root of a folder (or as the root of an npm package tagged with the tomat-extension keyword).",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "displayName", "description"],
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Machine name of the extension."
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name shown in the Extensions UI."
    },
    "description": { "type": "string", "minLength": 1 },
    "license": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "database": {
      "type": "boolean",
      "default": false,
      "description": "Whether the host should provision a private database for this extension, exposed to tools as ctx.db. Storage is host-defined."
    },
    "tools": {
      "type": "array",
      "default": [],
      "description": "Tools the extension provides. May be empty if the extension ships only memories.",
      "items": { "$ref": "#/$defs/tool" }
    },
    "memories": {
      "type": "array",
      "default": [],
      "description": "Knowledge and skills the extension ships, registered read-only on install.",
      "items": { "$ref": "#/$defs/memory" }
    }
  },
  "$defs": {
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": { "enum": ["knowledge", "skill"] },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?![/\\\\]|[A-Za-z]:)(?!.*(^|[/\\\\])\\.\\.([/\\\\]|$)).+$",
          "description": "Path relative to the extension root (no absolute paths or `..` segments): a .md file for knowledge, or a folder holding SKILL.md for a skill."
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "parameters", "function"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]{1,64}$",
          "description": "Machine name; must match ^[a-zA-Z0-9_-]{1,64}$ and be unique within the extension."
        },
        "description": { "type": "string", "minLength": 1 },
        "parameters": {
          "type": "object",
          "description": "JSON Schema (draft 2020-12) for the LLM-supplied arguments."
        },
        "triggers": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Example user prompts; used by the host for RAG-style relevance filtering."
        },
        "function": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the exported async function on the entry module that runs this tool."
        },
        "alwaysAvailable": { "type": "boolean", "default": false },
        "platforms": {
          "type": "array",
          "items": { "enum": ["darwin", "windows", "linux", "linux_x11", "linux_wayland"] },
          "default": [],
          "description": "Operating systems this tool runs on. Empty (or omitted) means every platform. 'linux' matches any Linux session; 'linux_x11' / 'linux_wayland' narrow to a display server. A tool is hidden everywhere on a host its list doesn't cover."
        },
        "permissions": {
          "type": "object",
          "additionalProperties": false,
          "default": {},
          "properties": {
            "net": {
              "type": "array",
              "items": { "$ref": "#/$defs/netPermission" },
              "default": []
            },
            "read": {
              "type": "array",
              "items": { "$ref": "#/$defs/pathPermission" },
              "default": []
            },
            "write": {
              "type": "array",
              "items": { "$ref": "#/$defs/pathPermission" },
              "default": []
            },
            "run": {
              "type": "array",
              "items": { "$ref": "#/$defs/runPermission" },
              "default": []
            },
            "env": {
              "type": "array",
              "items": { "$ref": "#/$defs/envPermission" },
              "default": []
            },
            "ffi": {
              "type": "array",
              "items": { "$ref": "#/$defs/ffiPermission" },
              "default": []
            },
            "sys": {
              "type": "array",
              "items": { "$ref": "#/$defs/sysPermission" },
              "default": []
            },
            "memories": {
              "type": "array",
              "items": { "$ref": "#/$defs/memoriesPermission" },
              "default": []
            },
            "llm": {
              "type": "array",
              "items": { "$ref": "#/$defs/modulePermission" },
              "default": []
            },
            "tts": {
              "type": "array",
              "items": { "$ref": "#/$defs/modulePermission" },
              "default": []
            },
            "stt": {
              "type": "array",
              "items": { "$ref": "#/$defs/modulePermission" },
              "default": []
            }
          }
        }
      }
    },
    "permissionReason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Human-readable rationale shown to the user when they're asked to grant this permission."
    },
    "netPermission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "ports", "reason"],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1,
          "description": "Hostname or '*' for any host."
        },
        "ports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [{ "type": "integer", "minimum": 1, "maximum": 65535 }, { "const": "*" }]
          }
        },
        "reason": { "$ref": "#/$defs/permissionReason" },
        "optional": { "type": "boolean", "default": false }
      }
    },
    "pathPermission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "reason"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Absolute path or template using $home, $downloads, $models, $sessions, $extension, $env.VAR."
        },
        "reason": { "$ref": "#/$defs/permissionReason" },
        "optional": { "type": "boolean", "default": false }
      }
    },
    "runPermission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binary", "reason"],
      "properties": {
        "binary": { "type": "string", "minLength": 1 },
        "reason": { "$ref": "#/$defs/permissionReason" },
        "optional": { "type": "boolean", "default": false }
      }
    },
    "envPermission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "reason"],
      "properties": {
        "key": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" },
        "reason": { "$ref": "#/$defs/permissionReason" },
        "optional": { "type": "boolean", "default": false }
      }
    },
    "ffiPermission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason"],
      "properties": {
        "reason": { "$ref": "#/$defs/permissionReason" },
        "optional": { "type": "boolean", "default": false }
      }
    },
    "sysPermission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["flag", "reason"],
      "properties": {
        "flag": { "type": "string", "minLength": 1 },
        "reason": { "$ref": "#/$defs/permissionReason" },
        "optional": { "type": "boolean", "default": false }
      }
    },
    "memoriesPermission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["access", "reason"],
      "properties": {
        "access": {
          "enum": ["read", "write"],
          "description": "Whether the tool reads the host's memory store or also writes to it."
        },
        "reason": { "$ref": "#/$defs/permissionReason" },
        "optional": { "type": "boolean", "default": false }
      }
    },
    "modulePermission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason"],
      "description": "All-or-nothing access to a host module (llm, tts, stt).",
      "properties": {
        "reason": { "$ref": "#/$defs/permissionReason" },
        "optional": { "type": "boolean", "default": false }
      }
    }
  }
}
