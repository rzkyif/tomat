---
// The no-JavaScript baseline of the install generator. Each instance covers ONE
// target (the Client or the Core), given as a prop; native <input type=radio> +
// CSS drive the OS selection and reveal the matching pre-rendered command, so a
// reader with JS off (or broken) still gets a working, selectable command to
// copy by hand. InstallGenerator.svelte mounts the enhanced version over this
// (live OS auto-detect, option toggles, copy button); the host page shows
// exactly one via the data-js gate.
//
// `mode` is "install" (the /install and cores pages) or "uninstall" (the removal
// page): same flow, with the uninstall one-liners, a flags note in place of the
// install options, and no installer download.
//
// Two instances can sit on one page (the uninstall page shows the Client and the
// Core), so ids/names are namespaced by target and the CSS toggles by the
// `data-os` attribute (scoped to each .ig root), never by a shared id.
//
// Channel is locked to `latest` here: stable has not shipped, so the baseline
// only renders the latest-channel one-liners. The enhanced island shows the
// (disabled) stable option for when it does.
import {
  androidApkUrl,
  CLIENT_OS,
  clientCommand,
  clientUninstallCommand,
  CORE_OS,
  coreCommand,
  coreUninstallCommand,
  finishHowto,
  INSTALLER_OPEN_STEP,
  installerSecurityStep,
  type NativeInstaller,
  nativeInstallers,
  openTerminalStep,
  RUN_COMMAND_STEP,
  type Target,
  uninstallStepsTail,
} from "../lib/install.ts";

interface Props {
  target: Target;
  mode?: "install" | "uninstall";
}
const { target, mode = "install" } = Astro.props;
const verb = mode === "install" ? "Install" : "Uninstall";
const uninstall = mode === "uninstall";
const CH = "latest";

const osChoices = target === "client" ? CLIENT_OS : CORE_OS;
const DESKTOP = ["macos", "linux", "windows"] as const;
type DesktopOs = (typeof DESKTOP)[number];

// The one-liner per desktop OS. Options are omitted from the pre-rendered command
// (a static page can't fold a toggle into it); the options note below carries
// them.
function cmdFor(os: DesktopOs): string {
  if (uninstall) {
    return target === "client"
      ? clientUninstallCommand(os, CH, { purge: false })
      : coreUninstallCommand(os, CH, { keepData: false });
  }
  return target === "client"
    ? clientCommand(os, CH)
    : coreCommand(os, CH, { bindAll: false, service: true, behindProxy: false });
}
const cmds: Record<DesktopOs, string> = {
  macos: cmdFor("macos"),
  linux: cmdFor("linux"),
  windows: cmdFor("windows"),
};

// Native double-click installers (the alternative to the terminal command),
// pre-rendered per desktop OS so the baseline can CSS-toggle the matching
// buttons like it does the commands. Android has none (it is the APK block).
const installers: Record<DesktopOs, NativeInstaller[]> = {
  macos: nativeInstallers(target, "macos", CH),
  linux: nativeInstallers(target, "linux", CH),
  windows: nativeInstallers(target, "windows", CH),
};
function installerLabel(list: NativeInstaller[], inst: NativeInstaller): string {
  const multi = new Set(list.map((i) => i.format)).size > 1;
  return multi ? `${inst.archLabel} · .${inst.format}` : inst.archLabel;
}

const apk = androidApkUrl(CH);

// Nested how-to (install): the install-script branch is an OS-specific opener
// plus the run-command line; the installer-download branch is a fixed open step
// plus the per-OS security step. The shared finishing steps are lifted to the
// top level (step 2+). The security step exists only on macOS (Gatekeeper) and
// Windows (SmartScreen); Linux has none.
const finishSteps = finishHowto(target);
const secMac = installerSecurityStep("macos", target);
const secWin = installerSecurityStep("windows", target);
// Uninstall how-to (terminal only): OS opener plus a fixed tail.
const uninstallTail = uninstallStepsTail(target);

// Unique per-target ids/names so the Client and Core instances on the uninstall
// page do not share a radio group; the CSS keys off data-os, not these ids.
const osId = (os: string) => `ig-os-${target}-${os}`;
const osName = `ig-os-${target}`;

const label = "text-xs font-medium uppercase tracking-wide text-default-500";
const btnBase =
  "flex items-center justify-center gap-2 px-3 py-2 rounded-medium text-sm transition-colors";
const osBtn = `ig-os-btn ${btnBase} bg-surface-inset text-default-700 hover:bg-surface-inset-strong cursor-pointer`;
const btnActive = `${btnBase} bg-default-inverted-300 text-default-inverted-900`;
// Download buttons reuse the OS-picker's idle look, minus the selected state.
const dlBtn = `${btnBase} bg-surface-inset text-default-700 hover:bg-surface-inset-strong cursor-pointer`;
const codeBox =
  "ig-cmd rounded-large bg-surface-inset px-4 py-3 font-mono text-sm text-default-800 overflow-x-auto whitespace-nowrap no-scrollbar";
---

{
  /* not-prose: the baseline can render inside the manual's `.prose` (the cores +
  uninstall pages), whose presetTypography would otherwise restyle the command
  `<code>` and the note paragraphs. No-op on /install, which has no prose
  ancestor. */
}
<div class="ig not-prose flex flex-col gap-6">
  {/* Operating system. */}
  <fieldset class="flex flex-col gap-2 border-0 p-0 m-0">
    <legend class={`${label} p-0`}>Operating System</legend>
    <div class={`grid gap-2 ${target === "client" ? "grid-cols-2 sm:grid-cols-4" : "grid-cols-3"}`}>
      {
        osChoices.map((o, i) => (
          <>
            <input
              id={osId(o.id)}
              name={osName}
              class="ig-radio sr-only"
              type="radio"
              data-os={o.id}
              checked={i === 0}
            />
            <label for={osId(o.id)} class={osBtn}>
              <i class={`${o.icon} text-lg`} />
              {o.label}
            </label>
          </>
        ))
      }
    </div>
  </fieldset>

  {/* Channel, locked to latest for now (stable not yet released). */}
  <div class="flex flex-col gap-2">
    <span class={label}>Channel</span>
    <div class="grid grid-cols-2 gap-2">
      <span class={`${btnBase} bg-surface-inset text-default-500 opacity-60 cursor-not-allowed`}>
        <i class="i-material-symbols-shield-outline-rounded text-lg"></i>
        Stable
      </span>
      <span class={btnActive}>
        <i class="i-material-symbols-bolt-rounded text-lg"></i>
        Latest
      </span>
    </div>
  </div>

  {
    /* Options: env vars (install core) or a keep-data flag (uninstall). Hidden on
  Android, which takes no flags. */
  }
  {
    !uninstall && target === "core" && (
      <div class="ig-optnote flex flex-col gap-2">
        <span class={label}>Options</span>
        <div class="flex flex-col gap-2 rounded-large bg-surface-inset px-4 py-3 text-sm text-default-700">
          <p class="m-0">Add these before running to change how the Core installs:</p>
          <ul class="m-0 flex flex-col gap-1 list-disc pl-5">
            <li>
              <span class="font-mono text-default-900">TOMAT_INSTALL_BIND_ALL=1</span>
              lets Clients on other machines pair with this Core.
            </li>
            <li>
              <span class="font-mono text-default-900">TOMAT_INSTALL_SERVICE=0</span>
              skips the background service so you start the Core by hand.
            </li>
            <li>
              <span class="font-mono text-default-900">TOMAT_INSTALL_BEHIND_PROXY=1</span>
              marks the Core as served through an HTTPS proxy, so pairing trusts the proxy's
              certificate. Set it before the first pair.
            </li>
          </ul>
          <p class="m-0">
            On macOS and Linux put them on the <span class="font-mono">bash</span> side of the pipe,
            e.g.{" "}
            <span class="font-mono text-default-900">curl ... | TOMAT_INSTALL_BIND_ALL=1 bash</span>
            . On Windows prefix the line, e.g.
            <span class="font-mono text-default-900">$env:TOMAT_INSTALL_BIND_ALL="1"; irm ...</span>
            .
          </p>
        </div>
      </div>
    )
  }
  {
    uninstall && target === "client" && (
      <div class="ig-optnote flex flex-col gap-2">
        <span class={label}>Options</span>
        <div class="flex flex-col gap-2 rounded-large bg-surface-inset px-4 py-3 text-sm text-default-700">
          <p class="m-0">By default this keeps your settings. To wipe them too, add a flag:</p>
          <p class="m-0">
            <span class="font-mono text-default-900">--purge</span>
            also deletes your saved settings and paired cores.
          </p>
          <p class="m-0">
            On macOS and Linux append it after <span class="font-mono">bash</span>, e.g.
            <span class="font-mono text-default-900">... | bash -s -- --purge</span>. On Windows
            prefix the line, e.g.
            <span class="font-mono text-default-900">$env:TOMAT_PURGE="1"; irm ...</span>.
          </p>
        </div>
      </div>
    )
  }
  {
    uninstall && target === "core" && (
      <div class="ig-optnote flex flex-col gap-2">
        <span class={label}>Options</span>
        <div class="flex flex-col gap-2 rounded-large bg-surface-inset px-4 py-3 text-sm text-default-700">
          <p class="m-0">
            By default this removes the Core and its data. To keep that data, add a flag:
          </p>
          <p class="m-0">
            <span class="font-mono text-default-900">--keep-data</span>
            keeps the Core's sessions and memories instead of removing them.
          </p>
          <p class="m-0">
            On macOS and Linux append it after <span class="font-mono">bash</span>, e.g.
            <span class="font-mono text-default-900">... | bash -s -- --keep-data</span>. On Windows
            prefix the line, e.g.
            <span class="font-mono text-default-900">$env:TOMAT_KEEP_DATA="1"; irm ...</span>.
          </p>
        </div>
      </div>
    )
  }

  {/* Terminal command, one pre-rendered box per desktop OS. */}
  <div class="ig-termsec flex flex-col gap-2">
    <span class={label}>{verb} via terminal</span>
    {DESKTOP.map((os) => <code class={`${codeBox} ig-cmd-${os}`}>{cmds[os]}</code>)}
  </div>

  {
    /* Android (client only) installs from a downloaded APK, not a command. Its
    own labeled block, shown only when Android is the selected OS. */
  }
  {
    target === "client" &&
      (uninstall ? (
        <div class="ig-android flex flex-col gap-2">
          <span class={label}>Remove</span>
          <div class="flex flex-col gap-3 rounded-large bg-surface-inset px-4 py-3">
            <p class="text-sm text-default-700 m-0">
              There is no script on Android. Remove tomat like any other app.
            </p>
            <ol class="m-0 flex flex-col gap-1 text-sm text-default-600 list-decimal pl-5">
              <li>Press and hold the tomat icon.</li>
              <li>Choose Uninstall (or drag it to Uninstall).</li>
              <li>Confirm to remove the app and its data.</li>
            </ol>
          </div>
        </div>
      ) : (
        <div class="ig-android flex flex-col gap-2">
          <span class={label}>Download</span>
          <div class="flex flex-col gap-3 rounded-large bg-surface-inset px-4 py-3">
            <p class="text-sm text-default-700 m-0">
              The Android app is a signed APK you install directly.
            </p>
            <a
              href={apk}
              class="inline-flex items-center justify-center gap-2 rounded-large bg-default-inverted-300 px-4 py-2.5 text-sm text-default-inverted-900 hover:cursor-pointer"
            >
              <i class="i-material-symbols-download-rounded text-lg" />
              Download the Android APK
            </a>
            <ol class="m-0 flex flex-col gap-1 text-sm text-default-600 list-decimal pl-5">
              <li>Open the downloaded file on your phone.</li>
              <li>If asked, allow installing apps from this source.</li>
              <li>Confirm the install, then open tomat.</li>
            </ol>
          </div>
        </div>
      ))
  }

  {
    /* Or download the installer (install only): one button per arch x format,
    CSS-toggled by the OS radios. */
  }
  {
    !uninstall && (
      <div class="ig-dlsec flex flex-col gap-2">
        <span class={label}>Or download the installer</span>
        {DESKTOP.map((os) => (
          <div class={`ig-dl ig-dl-${os} grid grid-cols-2 gap-2`}>
            {installers[os].map((inst) => (
              <a href={inst.url} class={dlBtn}>
                <i class="i-material-symbols-download-rounded text-lg" />
                {installerLabel(installers[os], inst)}
              </a>
            ))}
          </div>
        ))}
      </div>
    )
  }

  {
    /* How to. Install: a nested outline (the two entry points are the a/b
    branches under step one, each with its own numbered steps; the uninstall
    pointer is the last step, not a footer). Uninstall: a single terminal list. */
  }
  <div class="ig-howto flex flex-col gap-2">
    <span class={label}>How to {verb}</span>
    {
      uninstall ? (
        <ol class="m-0 flex flex-col gap-2 text-sm text-default-700 list-decimal pl-5">
          {DESKTOP.map((os) => (
            <li class={`ig-open ig-open-${os}`}>{openTerminalStep(os)}</li>
          ))}
          {uninstallTail.map((s) => (
            <li>{s}</li>
          ))}
        </ol>
      ) : (
        <ol class="m-0 flex flex-col gap-2 text-sm text-default-700 list-decimal pl-5">
          <li>
            Install with either path:
            {/* lower-alpha inline: the Uno list utilities are prose-gated, so they
            no-op inside this not-prose island; decimal/disc emit an ungated rule,
            but lower-alpha only comes from prose, so it needs an inline
            list-style-type to render the a./b. markers here. */}
            <ol class="mt-1.5 flex flex-col gap-1.5 pl-5" style="list-style-type: lower-alpha">
              <li>
                <span class="font-semibold text-default-800">Using the install script:</span>
                <ol class="mt-1 flex flex-col gap-1 list-decimal pl-5">
                  {DESKTOP.map((os) => (
                    <li class={`ig-open ig-open-${os}`}>{openTerminalStep(os)}</li>
                  ))}
                  <li>{RUN_COMMAND_STEP}</li>
                </ol>
              </li>
              <li>
                <span class="font-semibold text-default-800">Or download the installer:</span>
                <ol class="mt-1 flex flex-col gap-1 list-decimal pl-5">
                  <li>{INSTALLER_OPEN_STEP}</li>
                  {secMac && (
                    <li class="ig-sec ig-sec-macos">
                      {secMac.text}
                      <ul class="mt-1 flex flex-col gap-1 list-disc pl-5">
                        {secMac.sub.map((s) => (
                          <li>{s}</li>
                        ))}
                      </ul>
                    </li>
                  )}
                  {secWin && <li class="ig-sec ig-sec-windows">{secWin.text}</li>}
                </ol>
              </li>
            </ol>
          </li>
          {target === "client" && (
            <li>
              When it finishes, launch tomat and pick where the Core should run: on the same
              computer or{" "}
              <a href="/manual/maintenance/cores" class="underline hover:text-default-700">
                on a different one
              </a>
              .
            </li>
          )}
          {finishSteps.map((s) => (
            <li>{s}</li>
          ))}
          <li>
            If you ever need to uninstall, follow{" "}
            <a href="/manual/maintenance/uninstalling" class="underline hover:text-default-700">
              the uninstallation guide
            </a>
            .
          </li>
        </ol>
      )
    }
  </div>
</div>

<style>
  /* Selected OS button: the inverted fill of the segmented controls' knob,
     driven by the native radio that immediately precedes each label. */
  .ig-radio:checked + .ig-os-btn {
    background: var(--default-d-300);
    color: var(--default-d-900);
  }
  :global(html.dark) .ig-radio:checked + .ig-os-btn {
    background: var(--default-300);
    color: var(--default-900);
  }

  /* Keyboard focus lands on the visually-hidden radio; resurface the ring on
     its visible label. */
  .ig-radio:focus-visible + .ig-os-btn {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  /* OS -> which command / download / step shows. Keyed off the checked radio's
     data-os, scoped to each .ig root, so two instances stay independent. */
  .ig-cmd,
  .ig-dl,
  .ig-open,
  .ig-sec,
  .ig-android {
    display: none;
  }
  .ig:has(.ig-radio[data-os="macos"]:checked) .ig-cmd-macos,
  .ig:has(.ig-radio[data-os="linux"]:checked) .ig-cmd-linux,
  .ig:has(.ig-radio[data-os="windows"]:checked) .ig-cmd-windows {
    display: block;
  }
  .ig:has(.ig-radio[data-os="macos"]:checked) .ig-dl-macos,
  .ig:has(.ig-radio[data-os="linux"]:checked) .ig-dl-linux,
  .ig:has(.ig-radio[data-os="windows"]:checked) .ig-dl-windows {
    display: grid;
  }
  /* Opener + security how-to steps: list-item so the ordered list still numbers
     them; the hidden variants drop out of the count. */
  .ig:has(.ig-radio[data-os="macos"]:checked) .ig-open-macos,
  .ig:has(.ig-radio[data-os="linux"]:checked) .ig-open-linux,
  .ig:has(.ig-radio[data-os="windows"]:checked) .ig-open-windows,
  .ig:has(.ig-radio[data-os="macos"]:checked) .ig-sec-macos,
  .ig:has(.ig-radio[data-os="windows"]:checked) .ig-sec-windows {
    display: list-item;
  }
  /* Android (client only) has its own block and hides the desktop sections. */
  .ig:has(.ig-radio[data-os="android"]:checked) .ig-android {
    display: flex;
  }
  .ig:has(.ig-radio[data-os="android"]:checked) .ig-termsec,
  .ig:has(.ig-radio[data-os="android"]:checked) .ig-dlsec,
  .ig:has(.ig-radio[data-os="android"]:checked) .ig-howto,
  .ig:has(.ig-radio[data-os="android"]:checked) .ig-optnote {
    display: none;
  }
</style>
