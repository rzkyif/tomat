---
import { groupManual, type ManualEntry } from "../lib/manual";

interface Props {
  entries: ManualEntry[];
  currentId: string;
}
const { entries, currentId } = Astro.props;
const sections = groupManual(entries);

// SidebarItem-style rows (mirrors the app's settings sidebar). The section
// summary has a leading chevron where the app's icon sits; leaf rows have no
// icon and indent their text to line up with the summary text (pl-1.5 + chevron
// text-xl 1.25rem + gap-1.5 = 2rem -> pl-8), so items sit flush under the
// section label rather than to the left of it.
const rowBase = "flex items-center h-8 pr-2.5 gap-1.5 rounded-medium transition-colors";
---

<nav class="flex flex-col gap-1 text-sm" aria-label="User manual">
  {sections.map((section) => {
    const open = section.entries.some((e) => e.id === currentId);
    return (
      <details class="expandable" open={open}>
        <summary
          class={`${rowBase} pl-1.5 text-default-500 hover:text-default-700 hover:bg-surface-inset hover:cursor-pointer select-none`}
        >
          <i class="expandable-chevron flex text-xl shrink-0 i-material-symbols-chevron-right-rounded"></i>
          {section.name}
        </summary>
        <div class="mt-1 flex flex-col gap-1">
          {section.entries.map((entry) => {
            const current = entry.id === currentId;
            return (
              <a
                href={`/manual/${entry.id}`}
                aria-current={current ? "page" : undefined}
                data-outline-current={current ? "" : undefined}
                class:list={[
                  rowBase,
                  "pl-8",
                  current
                    ? "bg-surface-inset text-default-900"
                    : "text-default-500 hover:text-default-700 hover:bg-surface-inset",
                ]}
              >
                {entry.data.title}
              </a>
            );
          })}
        </div>
      </details>
    );
  })}
</nav>
