---
import { getCollection } from "astro:content";
import { activePageId, GITHUB_URL, PAGES } from "../lib/site";
import ThemeToggle from "./ThemeToggle.svelte";
import ManualOutline from "./ManualOutline.astro";
import IconButton from "@tomat/shared/ui/components/primitives/IconButton.svelte";

const active = activePageId(Astro.url.pathname);
// Cells size to their label (not flex-1 equal columns) so the inter-page gap is
// uniform; the knob then measures the active cell at runtime and grows/shrinks
// to fit it as it slides (see the script below).
const cell =
  "flex items-center justify-center px-3 text-sm whitespace-nowrap";

// The mobile sidebar self-contains the manual section/subsection tree (rather
// than being fed by the layout), so it nests three levels everywhere: page >
// section > subsection. It lives OUTSIDE the persisted <nav> so it re-renders
// per page and its highlight/open state is always current.
const manualEntries = (await getCollection("manual")).sort(
  (a, b) => a.data.order - b.data.order,
);
const path = Astro.url.pathname.replace(/\/$/, "");
const currentManualId = path.startsWith("/manual/")
  ? path.slice("/manual/".length)
  : "";

// SidebarItem-style rows (mirrors the app's settings sidebar): no icons, an
// expand chevron where the icon would sit. A w-5 spacer keeps icon-less top
// level rows' labels aligned with the chevron rows.
const row =
  "flex items-center h-8 pl-1.5 pr-2.5 gap-1.5 rounded-medium transition-colors";
const rowIdle =
  "text-default-500 hover:text-default-700 hover:bg-surface-inset";
const rowActive = "bg-surface-inset text-default-900";
---

{
  /* The sticky top chrome: a thin pre-release banner stacked above the navbar
    bar, pinned together so both stay visible while the page scrolls under them.
    transition:persist keeps the header mounted across view transitions (so the
    knob can slide to the new page, updated by the script below); persist alone
    keeps the DOM node, but its pixels are still captured into the `root`
    snapshot and would slide with the page, so the `vt-chrome` class (site.css)
    gives it its own view-transition-name to lift it into a static group while
    the page content slides under it. The sidebar/scrim are intentionally NOT
    inside this element, so they re-render per page with correct highlights. */
}
<header
  transition:persist="chrome"
  class="vt-chrome sticky top-0 z-50"
>
  {
    /* Pre-release notice. Auto-height (no fixed height) so it grows to two-plus
      lines when the copy wraps on narrow screens; the header's measured height
      feeds --chrome-h (see BaseLayout) so everything below tracks it. */
  }
  <div
    class="flex items-center justify-center bg-accent-yellow-300 px-4 py-1 text-center text-xs text-accent-yellow-900"
  >
    This website is currently in a pre-release demo state and may contain incorrect information.
  </div>
  <nav class="h-14 bg-surface">
  <div
    class="relative mx-auto h-full w-full max-w-6xl px-5 md:px-4 flex items-center justify-between"
  >
    {
      /* Left: the tomat icon, painted as a theme-adaptive mask (same technique as
        the app) so it flips with light/dark instead of staying a fixed color.
        Navbar `xl` IconButton scale, matching the GitHub + burger icons. */
    }
    <IconButton
      href="/"
      size="xl"
      title="tomat home"
      ariaLabel="tomat home"
      class="-ml-1"
    >
      <span
        class="block w-7 h-7 bg-current"
        style="mask:url(/logo.svg) center/contain no-repeat;-webkit-mask:url(/logo.svg) center/contain no-repeat;"
        aria-hidden="true"></span>
    </IconButton>

    {
      /* Center (desktop): the segmented tab selector, link-based so it works with
        no JS. Absolutely centered on the row so it sits at the true center
        regardless of the differing logo / GitHub+theme widths. */
    }
    <div
      class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2"
    >
      <div
        data-nav-groove
        class="groove relative flex items-center gap-1 h-10 rounded-large bg-surface-inset p-1"
        role="tablist"
        aria-label="Site"
      >
        {
          PAGES.map((p) => (
            <a
              href={p.href}
              role="tab"
              data-nav-cell
              aria-selected={p.id === active}
              class={`${cell} transition-colors ${
                p.id === active
                  ? "text-default-900"
                  : "text-default-600 hover:text-default-800"
              }`}
            >
              {p.label}
            </a>
          ))
        }
        {
          /* The knob is the same labels in the active color, laid out identically
            so they sit exactly over the links, then clipped to the active cell's
            measured rect (set by the script). It starts hidden (opacity-0) until
            the script measures it, so there is no first-paint flash; with no JS
            the active link's own text-default-900 still marks the page. */
        }
        <span
          aria-hidden="true"
          data-nav-knob
          class="nav-knob absolute inset-0 flex items-center gap-1 p-1 bg-surface-inset-strong text-default-900 pointer-events-none opacity-0"
        >
          {PAGES.map((p) => <span class={cell}>{p.label}</span>)}
        </span>
      </div>
    </div>

    {/* Right (desktop): GitHub + theme, both at the navbar `xl` icon scale. */}
    <div class="hidden md:flex items-center gap-1 shrink-0 -mr-1">
      <IconButton
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        size="xl"
        icon="i-mdi-github"
        title="tomat on GitHub"
        ariaLabel="tomat on GitHub"
      />
      <ThemeToggle client:load />
    </div>

    {
      /* Right (mobile): burger that morphs to an X. Pure CSS via a hidden
        checkbox so it works with no JS. The IconButton renders as a `<label>`
        (forId) and centers the three bars; the morph CSS targets `.burger .bar`. */
    }
    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle sr-only"
      aria-hidden="true"
    />
    <IconButton
      forId="nav-toggle"
      size="xl"
      title="Open menu"
      ariaLabel="Open menu"
      class="burger md:hidden -mr-1"
    >
      <span class="burger-bars flex flex-col justify-center gap-1.5 w-7">
        <span
          class="bar block h-0.5 w-full bg-default-800 rounded transition-transform"
        ></span>
        <span
          class="bar block h-0.5 w-full bg-default-800 rounded transition-opacity"
        ></span>
        <span
          class="bar block h-0.5 w-full bg-default-800 rounded transition-transform"
        ></span>
      </span>
    </IconButton>
  </div>
  </nav>
</header>

{
  /* Mobile menu + scrim. A full-width panel that drops down from under the chrome
    to fit its content (not a full-height drawer). Outside the persisted <header>
    so they re-render per page (correct highlights), toggled by the persisted
    checkbox via :has. */
}
<label for="nav-toggle" class="scrim md:hidden" aria-hidden="true"></label>
<aside
  class="sidebar tomat-scroll md:hidden fixed top-[var(--chrome-h)] left-0 right-0 z-40 bg-surface flex flex-col max-h-[calc(100dvh-var(--chrome-h))] overflow-y-auto"
>
  <nav class="p-3 flex flex-col gap-1" aria-label="Site">
    <a
      href="/"
      class:list={[row, active === "home" ? rowActive : rowIdle]}
      aria-current={active === "home" ? "page" : undefined}
    >
      <span class="w-5 shrink-0"></span>
      Home
    </a>

    <a
      href="/install"
      class:list={[row, active === "install" ? rowActive : rowIdle]}
      aria-current={active === "install" ? "page" : undefined}
    >
      <span class="w-5 shrink-0"></span>
      Install
    </a>

    {
      /* User Manual: expandable, open on a manual page; subsections navigate. */
    }
    <details class="expandable" open={active === "manual"}>
      <summary class:list={[row, rowIdle, "hover:cursor-pointer select-none"]}>
        <i
          class="expandable-chevron flex text-xl shrink-0 i-material-symbols-chevron-right-rounded"
        ></i>
        User Manual
      </summary>
      <div class="mt-1 pl-3.5">
        <ManualOutline entries={manualEntries} currentId={currentManualId} />
      </div>
    </details>

    <a
      href="/gallery"
      class:list={[row, active === "gallery" ? rowActive : rowIdle]}
      aria-current={active === "gallery" ? "page" : undefined}
    >
      <span class="w-5 shrink-0"></span>
      Gallery
    </a>
  </nav>

  {
    /* Footer: GitHub and the theme toggle side by side, as filled card buttons
      (the client's button style) rather than flat rows. */
  }
  <div class="p-3 pt-0 flex gap-2">
    <a
      href={GITHUB_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="flex flex-1 items-center justify-center gap-2 h-10 px-4 rounded-medium bg-surface-inset text-default-700 hover:bg-surface-inset-strong hover:text-default-900 transition-colors"
    >
      <i class="flex text-lg shrink-0 i-mdi-github"></i>
      <span class="flex-1 text-center">GitHub</span>
      <i class="flex text-lg shrink-0 i-mdi-github invisible" aria-hidden="true"></i>
    </a>
    <ThemeToggle client:load variant="card" />
  </div>
</aside>

<style>
  /* The burger/sidebar mechanism is a CSS-only checkbox toggle so the menu
     opens, the icon morphs to an X, and the panel slides in without any JS. The
     checkbox lives in the persisted nav and the sidebar outside it, so the
     toggle is keyed off a common ancestor (body) via :has rather than a sibling
     combinator. */
  .nav-toggle {
    position: absolute;
  }
  /* The panel drops down from under the chrome (translateY), sitting BELOW the
     chrome in the stack (z-40 vs the chrome's z-50) so that while hidden above
     its --chrome-h anchor it stays tucked behind the opaque bar. */
  .sidebar {
    transform: translateY(-100%);
    transition: transform 250ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .scrim {
    position: fixed;
    inset: var(--chrome-h) 0 0 0;
    background: rgba(0, 0, 0, 0.35);
    opacity: 0;
    pointer-events: none;
    transition: opacity 250ms ease;
    z-index: 30;
  }
  :global(body):has(.nav-toggle:checked) .sidebar {
    transform: translateY(0);
  }
  :global(body):has(.nav-toggle:checked) .scrim {
    opacity: 1;
    pointer-events: auto;
  }
  /* Burger -> X morph (checkbox and burger are siblings inside the nav). The
     bars live in `.burger-bars` (the slotted wrapper inside the IconButton
     label), not on the label itself, so the label being rendered by the shared
     component does not affect Astro's style scoping. */
  nav:has(.nav-toggle:checked) .burger-bars .bar:nth-child(1) {
    transform: translateY(0.5rem) rotate(45deg);
  }
  nav:has(.nav-toggle:checked) .burger-bars .bar:nth-child(2) {
    opacity: 0;
  }
  nav:has(.nav-toggle:checked) .burger-bars .bar:nth-child(3) {
    transform: translateY(-0.5rem) rotate(-45deg);
  }
  /* Keyboard focus lands on the visually-hidden checkbox, so resurface the
     focus ring on the visible burger bars (mirrors the :checked selector
     structure, since the label's class can't be Astro-scoped from here). */
  nav:has(.nav-toggle:focus-visible) .burger-bars {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }
  /* The active-page knob slides to its new clip rect (set by the script on
     navigation) instead of snapping. */
  .nav-knob {
    transition: clip-path 260ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-knob {
      transition: none;
    }
  }
</style>

<script>
  // The top chrome is persisted across view transitions, so after each
  // navigation the knob still sits over the previous page: re-measure the active
  // cell and clip the knob to it (the CSS transition turns the changing rect into
  // a grow/shrink slide). Cells are content-sized, so the rect can only be known
  // at runtime; with no JS the active link's text-default-900 still marks the
  // page. Also close the (persisted) burger menu after navigating.
  import { activePageId, PAGES } from "../lib/site";

  // First placement (and every resize) snaps; only navigation slides.
  let initialized = false;

  function positionKnob() {
    const groove = document.querySelector<HTMLElement>("[data-nav-groove]");
    if (!groove) return;
    const knob = groove.querySelector<HTMLElement>("[data-nav-knob]");
    const cells = Array.from(
      groove.querySelectorAll<HTMLElement>("[data-nav-cell]"),
    );
    const index = Math.max(
      0,
      PAGES.findIndex((p) => p.id === activePageId(location.pathname)),
    );
    const cell = cells[index];
    if (!knob || !cell) return;

    // Keep the link colors in sync (the no-JS fallback indicator).
    cells.forEach((c, i) => {
      const on = i === index;
      c.setAttribute("aria-selected", String(on));
      c.classList.toggle("text-default-900", on);
      c.classList.toggle("text-default-600", !on);
      c.classList.toggle("hover:text-default-800", !on);
    });

    // Clip the full-width knob to the active cell's rect. The knob is inset-0
    // over the groove, so cell rects taken relative to the groove map straight
    // onto the knob's coordinate space. The 4px vertical inset matches p-1.
    const g = groove.getBoundingClientRect();
    const c = cell.getBoundingClientRect();
    const left = Math.round(c.left - g.left);
    const right = Math.round(g.right - c.right);
    const clip = `inset(4px ${right}px 4px ${left}px round var(--rounded-large))`;

    if (initialized) {
      knob.style.clipPath = clip;
      knob.style.opacity = "1";
    } else {
      // Apply without the slide on first paint / after a resize.
      knob.style.transition = "none";
      knob.style.clipPath = clip;
      knob.style.opacity = "1";
      knob.getBoundingClientRect();
      knob.style.transition = "";
      initialized = true;
    }
  }

  function onLoad() {
    positionKnob();
    const toggle = document.getElementById(
      "nav-toggle",
    ) as HTMLInputElement | null;
    if (toggle) toggle.checked = false;
  }

  document.addEventListener("astro:page-load", onLoad);
  window.addEventListener("resize", () => {
    initialized = false;
    positionKnob();
  });
</script>
