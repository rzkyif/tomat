---
import BaseLayout from "./BaseLayout.astro";
import ManualOutline from "../components/ManualOutline.astro";
import type { ManualEntry } from "../lib/manual";

interface Props {
  title: string;
  entries: ManualEntry[];
  currentId: string;
}
const { title, entries, currentId } = Astro.props;
---

<BaseLayout title={title} description={title}>
  <div class="mx-auto flex w-full max-w-6xl gap-8 px-5 py-8 md:px-4">
    {/* Desktop: a left outline sidebar, sticky under the navbar. */}
    <aside class="hidden md:block w-60 shrink-0">
      <div class="tomat-scroll sticky top-[5.5rem] max-h-[calc(100dvh-7rem)] overflow-y-auto pr-2">
        <ManualOutline entries={entries} currentId={currentId} defaultOpen />
      </div>
    </aside>

    <main class="manual-article relative min-w-0 flex-1">
      {/* The focus grid lives behind the article content and tracks this column's
          width and full scroll height (see `.focus-grid-manual` in site.css). */}
      <div class="focus-grid-manual" aria-hidden="true"></div>
      <slot />
    </main>
  </div>

  {/* Soft scroll fades, fixed to the viewport: the top one sits just under the
      sticky navbar (top-14), the bottom one hugs the window edge. Each shows
      only when the window can still scroll that way, toggled by the script
      below. Mirrors the settings panel's scroll-area fades (SettingsShellView):
      from-default-50 matches the page's bg-surface, z-40 keeps them under the
      navbar's z-50. */}
  <div
    id="manual-fade-top"
    aria-hidden="true"
    class="pointer-events-none fixed left-0 right-0 top-14 z-40 h-6 bg-gradient-to-b from-default-50 to-transparent opacity-0 transition-opacity duration-100"
  >
  </div>
  <div
    id="manual-fade-bottom"
    aria-hidden="true"
    class="pointer-events-none fixed bottom-0 left-0 right-0 z-40 h-6 bg-gradient-to-t from-default-50 to-transparent opacity-0 transition-opacity duration-100"
  >
  </div>
</BaseLayout>

<script>
  // When the mobile burger menu opens, bring the current subsection in the
  // injected outline into view. Optional enhancement: with no JS the outline is
  // still fully scrollable by hand.
  function wireOutlineAutoscroll() {
    const toggle = document.getElementById("nav-toggle") as HTMLInputElement | null;
    if (!toggle) return;
    toggle.addEventListener("change", () => {
      if (!toggle.checked) return;
      const current = document.querySelector<HTMLElement>(".sidebar [data-outline-current]");
      current?.scrollIntoView({ block: "center" });
    });
  }

  // Scale-to-fit for `.demo-scale` demos: the same idea as the homepage showcase
  // (measure the available width, CSS-scale a fixed design box to fit), but run
  // over static markup so the demos themselves stay un-hydrated. A wide demo (the
  // settings panel) shrinks as a whole instead of reflowing on a narrow screen.
  let demoRO: ResizeObserver | null = null;
  function scaleDemo(wrap: HTMLElement) {
    const w = parseFloat(wrap.dataset.demoW ?? "");
    if (!w) return;
    const box = wrap.querySelector<HTMLElement>(".demo-scale-box");
    const inner = wrap.querySelector<HTMLElement>(".demo-scale-inner");
    if (!box || !inner) return;
    // Mark scaled first, which drops the pre-script max-width cap so `inner`
    // measures at its full design width.
    wrap.dataset.scaled = "1";
    const naturalH = inner.offsetHeight;
    // Fit the design box into the column, then (if set) cap the rendered height
    // so a tall design stays a compact inline demo at its true proportions.
    let scale = Math.min(1, wrap.clientWidth / w);
    const maxH = parseFloat(wrap.dataset.demoMaxh ?? "");
    if (maxH && naturalH * scale > maxH) scale = maxH / naturalH;
    inner.style.transform = scale < 1 ? `scale(${scale})` : "";
    box.style.width = `${w * scale}px`;
    box.style.height = `${naturalH * scale}px`;
  }
  function wireDemoScale() {
    demoRO?.disconnect();
    const wraps = Array.from(document.querySelectorAll<HTMLElement>(".demo-scale"));
    if (!wraps.length) return;
    demoRO = new ResizeObserver((entries) => {
      for (const e of entries) {
        const wrap = (e.target as HTMLElement).closest<HTMLElement>(".demo-scale");
        if (wrap) scaleDemo(wrap);
      }
    });
    for (const wrap of wraps) {
      scaleDemo(wrap);
      demoRO.observe(wrap); // column width changes
      const inner = wrap.querySelector<HTMLElement>(".demo-scale-inner");
      if (inner) demoRO.observe(inner); // natural height changes (fonts, content)
    }
  }

  // Position a target-mode Highlight overlay over one element inside a demo (the
  // core chip in the session bar, the mic in the composer). The overlay and the
  // target share the same `.demo-scale-inner` box, so layout offsets (which
  // ignore the CSS scale transform) place it correctly at any column width. Runs
  // over static markup, like wireDemoScale, so the demos stay un-hydrated.
  function positionHighlight(overlay: HTMLElement) {
    const root = overlay.closest<HTMLElement>("[data-highlight-root]");
    const sel = overlay.dataset.highlightTarget;
    if (!root || !sel) return;
    const targetEl = root.querySelector<HTMLElement>(sel);
    if (!targetEl) {
      overlay.hidden = true;
      return;
    }
    let top = 0;
    let left = 0;
    let node: HTMLElement | null = targetEl;
    while (node && node !== root) {
      top += node.offsetTop;
      left += node.offsetLeft;
      node = node.offsetParent as HTMLElement | null;
    }
    overlay.style.top = `${top - 4}px`;
    overlay.style.left = `${left - 4}px`;
    overlay.style.width = `${targetEl.offsetWidth + 8}px`;
    overlay.style.height = `${targetEl.offsetHeight + 8}px`;
    overlay.hidden = false;
  }
  function wireDemoHighlights() {
    const overlays = Array.from(
      document.querySelectorAll<HTMLElement>("[data-highlight-target]"),
    );
    for (const o of overlays) positionHighlight(o);
  }

  // Toggle the viewport scroll fades from the window scroll position: the top
  // fade once scrolled away from the top, the bottom fade while content remains
  // below the fold. Re-queries the overlays each call since they re-render per
  // page (the window, where the listeners live, persists across navigations).
  function updateScrollFades() {
    const top = document.getElementById("manual-fade-top");
    const bottom = document.getElementById("manual-fade-bottom");
    if (!top || !bottom) return;
    const max = document.documentElement.scrollHeight - globalThis.innerHeight;
    top.style.opacity = globalThis.scrollY > 1 ? "1" : "0";
    bottom.style.opacity = globalThis.scrollY < max - 1 ? "1" : "0";
  }

  function wire() {
    wireOutlineAutoscroll();
    wireDemoScale();
    // After scaling, since a target's offsets can shift as the scaled box and
    // fonts settle.
    wireDemoHighlights();
    // Set the fades' initial state for the freshly-swapped page.
    updateScrollFades();
  }
  wire();
  document.addEventListener("astro:page-load", wire);
  // The demo ResizeObserver already re-scales on column/content changes; keep the
  // highlight overlays pinned to their targets across those same reflows.
  globalThis.addEventListener("resize", wireDemoHighlights);
  // Window-level listeners registered once: the window persists across view
  // transitions, so wiring these per page would stack duplicates.
  globalThis.addEventListener("scroll", updateScrollFades, { passive: true });
  globalThis.addEventListener("resize", updateScrollFades);
</script>
