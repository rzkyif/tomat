---
// The shared design tokens. The UnoCSS reset + generated utilities are injected
// by the unocss/astro integration; this brings the color ladders, bubble
// visuals, roundedness, and font variables that the shared components paint
// from. One source of truth with the client (packages/tomat-shared/src/ui).
import "@tomat/shared/ui/styles/base.css";
import "../styles/site.css";
import { ClientRouter } from "astro:transitions";
import { getCollection } from "astro:content";
import { groupManual } from "../lib/manual";
import { PAGES } from "../lib/site";
import Navbar from "../components/Navbar.astro";

interface Props {
  title?: string;
  description?: string;
}
const { title = "tomat", description = "tomat" } = Astro.props;

// The navbar's top-level pages, left-to-right, as the hrefs the inline
// direction script compares to pick a slide direction (a later page = a larger
// index = slides forward/up). The manual entry's href matches any of its
// subsections.
const navOrder = PAGES.map((p) => p.href);

// The manual outline's flat top-to-bottom order, as `/manual/<id>` paths. The
// inline direction script below reads it to decide which way a manual ->
// manual navigation slides (lower item = later index = slides up).
const manualOrder = groupManual(await getCollection("manual"))
  .flatMap((s) => s.entries)
  .map((e) => `/manual/${e.id}`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    {/* No-flash theme: set the .dark class before first paint from the saved
        preference, falling back to the OS setting. is:inline keeps it out of
        the bundle so it runs synchronously in <head>. Re-applied on
        astro:after-swap because view transitions reset documentElement's class
        list and inline style to the freshly-served page (which has neither
        .dark nor the font vars), so without this the theme and fonts reset on
        every navigation. Setting --font-default / --font-mono inline mirrors how
        the client applies its font settings: an inline value always wins over a
        :root declaration, so the design-system fonts hold even if a stylesheet
        loads late or re-declares them (the source of the mono flicker). */}
    <script is:inline>
      (function () {
        var SANS =
          '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif';
        var MONO = 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace';
        function apply() {
          try {
            var de = document.documentElement;
            var saved = localStorage.getItem("tomat-theme");
            var dark = saved ? saved === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
            de.classList.toggle("dark", dark);
            de.style.setProperty("--font-default", SANS);
            de.style.setProperty("--font-mono", MONO);
          } catch (_) {}
        }
        apply();
        document.addEventListener("astro:after-swap", apply);
      })();
    </script>
    {/* Publish the sticky chrome's real height (the pre-release banner + navbar)
        as --chrome-h, so every offset that hangs off the bottom of the chrome
        (the mobile menu + scrim, the scroll fades, the viewport-fit page heights)
        tracks it. The banner wraps to two-plus lines on narrow screens, so its
        height is only known at runtime; measure the rendered header and re-measure
        on resize. Re-applied on astro:after-swap because the swap resets
        documentElement's inline style (same reason as the theme script); the CSS
        :root fallback covers first paint and the no-JS case. */}
    <script is:inline>
      (function () {
        function apply() {
          var el = document.querySelector(".vt-chrome");
          if (el) {
            document.documentElement.style.setProperty("--chrome-h", el.offsetHeight + "px");
          }
        }
        addEventListener("DOMContentLoaded", apply);
        addEventListener("resize", apply);
        document.addEventListener("astro:after-swap", apply);
        document.addEventListener("astro:page-load", apply);
      })();
    </script>
    {/* Direction-aware page slide: tag <html> with the travel direction before
        each view transition, which the CSS in site.css turns into a slide.
        Crossing between the navbar's top-level pages (home/install/manual/gallery,
        ordered by #nav-order) slides horizontally on desktop (forward/back) and
        vertically on mobile (page-up/page-down); moving between manual subsections
        slides vertically (up/down) along the outline order published in
        #manual-order. The
        direction is computed in before-preparation (so the old snapshot is named
        for the vertical case) and re-applied in after-swap: the swap resets
        documentElement's attributes to the incoming page, and the new snapshot
        plus the pseudo-element animations are resolved after that, so without
        re-applying, both fall back to the default cross-fade. */}
    {/* Staged homepage reveal. Marking the document JS-capable lets site.css hide
        the hero (the "Get tomat" button and the showcase) until the showcase
        signals it has measured and settled (`main[data-ready]`), so its
        load-time layout settling is never seen as a shift. is:inline so it runs
        before first paint; no-JS renders everything immediately (this never
        runs). The timeout is a fail-safe in case the showcase never signals. */}
    <script is:inline>
      document.documentElement.setAttribute("data-js", "");
      addEventListener("DOMContentLoaded", function () {
        setTimeout(function () {
          var m = document.querySelector("main");
          if (m) m.setAttribute("data-ready", "");
        }, 2500);
      });
    </script>
    {/* Critical styles for the staged homepage reveal. Inlined render-blocking
        (not UnoCSS utilities, which are injected by JS in dev) so the scrim
        covers the showcase on the VERY FIRST paint: otherwise the showcase
        flashes in for a frame before the cover applies, then re-appears on
        reveal. The scrim fades OUT and the button fades IN once the showcase has
        measured and settled (`main[data-ready]`, set by the island). Fading the
        section's own opacity is avoided on purpose: opacity < 1 on a bubble
        ancestor kills its `backdrop-filter` halo in WebKit, so the showcase is
        revealed via a sibling scrim instead. */}
    <style is:inline>
      /* Pin the scrim's containing block here too, so it does not re-anchor when
         the `relative` UnoCSS utility loads. */
      .showcase-section {
        position: relative;
      }
      /* Until the showcase signals it has settled, hide the section's CONTENT with
         `visibility` (which never paints, so no compositor glitch during island
         hydration can flash it) while keeping the scrim itself painted to cover.
         `visibility`, not `opacity`/`filter`: those on a bubble ancestor would
         kill its `backdrop-filter` halo in WebKit; visibility does not, and the
         bubbles establish their halo cleanly when first painted on reveal. */
      html[data-js] .showcase-section {
        visibility: hidden;
      }
      html[data-js] main[data-ready] .showcase-section {
        visibility: visible;
      }
      .showcase-scrim {
        position: absolute;
        inset: 0;
        z-index: 40;
        pointer-events: none;
        opacity: 0;
        visibility: visible;
        /* Fallbacks keep the cover opaque even for the frame before the token
           sheet applies; they resolve to the real surface color once it does. */
        background: var(--default-50, #ffffff);
      }
      html.dark .showcase-scrim {
        background: var(--default-d-50, #0a0a0a);
      }
      html[data-js] .showcase-scrim {
        opacity: 1;
      }
      html[data-js] .home-reveal {
        opacity: 0;
      }
      html[data-js] main[data-ready] .home-reveal {
        opacity: 1;
        transition: opacity 450ms ease;
      }
      html[data-js] main[data-ready] .showcase-scrim {
        opacity: 0;
        transition: opacity 450ms ease 300ms;
      }
      @media (prefers-reduced-motion: reduce) {
        html[data-js] main[data-ready] .home-reveal,
        html[data-js] main[data-ready] .showcase-scrim {
          transition-duration: 0ms;
        }
      }
    </style>
    <script is:inline id="nav-order" type="application/json" set:html={JSON.stringify(navOrder)} />
    <script is:inline id="manual-order" type="application/json" set:html={JSON.stringify(manualOrder)} />
    <script is:inline>
      (function () {
        var dir = "none";
        function norm(p) {
          return p.length > 1 && p.charAt(p.length - 1) === "/" ? p.slice(0, -1) : p;
        }
        function isManual(p) {
          return p.indexOf("/manual") === 0;
        }
        function readOrder(id) {
          var el = document.getElementById(id);
          if (!el) return [];
          try {
            return JSON.parse(el.textContent || "[]");
          } catch (_) {
            return [];
          }
        }
        function manualIndex(p) {
          return readOrder("manual-order").indexOf(p);
        }
        // Position of a pathname among the navbar's top-level pages. The manual
        // entry's href matches any /manual subsection (the tab covers the whole
        // manual), so all manual pages share the manual's navbar slot.
        function navIndex(p) {
          var order = readOrder("nav-order");
          for (var i = 0; i < order.length; i++) {
            var h = norm(order[i]);
            if (isManual(h) ? isManual(p) : h === p) return i;
          }
          return -1;
        }
        document.addEventListener("astro:before-preparation", function (e) {
          dir = "none";
          try {
            var from = norm(new URL(e.from).pathname);
            var to = norm(new URL(e.to).pathname);
            if (isManual(from) && isManual(to)) {
              // Within the manual: slide vertically along the outline order (a
              // lower item = later index = slides up); only the article is named
              // for this, so the outline sidebar stays put.
              var fi = manualIndex(from);
              var ti = manualIndex(to);
              if (fi !== -1 && ti !== -1 && fi !== ti) dir = ti > fi ? "up" : "down";
            } else {
              // Crossing the navbar's top-level pages. On desktop the tab
              // selector is a horizontal control, so the whole page slides
              // sideways (forward = a later page in the navbar, back = earlier).
              // On mobile (selector hidden, navigation is the vertical burger
              // list) it slides vertically instead: a later page slides up, an
              // earlier one slides down.
              var fn = navIndex(from);
              var tn = navIndex(to);
              if (fn !== -1 && tn !== -1 && fn !== tn) {
                var forward = tn > fn;
                if (matchMedia("(min-width: 768px)").matches) {
                  dir = forward ? "forward" : "back";
                } else {
                  dir = forward ? "page-up" : "page-down";
                }
              }
            }
          } catch (_) {}
          document.documentElement.dataset.vtDir = dir;
        });
        document.addEventListener("astro:after-swap", function () {
          document.documentElement.dataset.vtDir = dir;
        });
      })();
    </script>
    <ClientRouter />
  </head>
  <body class="bg-surface text-default-800 font-sans">
    <Navbar />
    <slot />
  </body>
</html>
