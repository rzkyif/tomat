---
import { getCollection, render } from "astro:content";
import ManualLayout from "../../layouts/ManualLayout.astro";
import { gitLastUpdated } from "../../lib/git-date";

export async function getStaticPaths() {
  const entries = await getCollection("manual");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, entries, lastUpdated: gitLastUpdated(entry.filePath) },
  }));
}

const { entry, entries, lastUpdated } = Astro.props;
const { Content } = await render(entry);
---

<ManualLayout title={entry.data.title} entries={entries} currentId={entry.id}>
  <header class="mb-6">
    <div class="text-xs font-semibold uppercase tracking-wide text-default-500">
      {entry.data.section}
    </div>
    <h1 class="mt-1 text-3xl font-semibold text-default-900">{entry.data.title}</h1>
    <div class="mt-1 text-xs text-default-500">Last updated {lastUpdated}</div>
  </header>

  {/* Demos live inline inside the MDX, rendered at the point each system is
      discussed (see the root COPY.md), so the page shell only frames the prose. */}
  <div class="prose dark:prose-invert max-w-none">
    <Content />
  </div>
</ManualLayout>
