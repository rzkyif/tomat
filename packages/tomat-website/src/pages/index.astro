---
import BaseLayout from "../layouts/BaseLayout.astro";
import InstallCard from "../components/InstallCard.svelte";
import Showcase from "../components/showcase/Showcase.svelte";
---

<BaseLayout title="tomat" description="A local-first AI client.">
  {/* A single, non-scrolling viewport under the sticky navbar. The install
      section (with its expandable "How to install") claims its height first; the
      feature showcase scales its demo to the leftover space and hugs it, so the
      whole column centers as one group. The showcase track is full-bleed (so
      neighbouring stages can peek on wide screens) while the caption, indicator,
      and install stay capped to the install-card width. `data-install` lets the
      showcase measure this row's height when sizing the demo. The top padding is
      the bar->install gap (gap-6/gap-10) minus the navbar's own 0.5rem padding
      below its tab nav, so the navbar->showcase gap matches the other two. */}
  <main class="h-[calc(100dvh-3.5rem)] flex flex-col justify-center gap-6 sm:gap-10 pt-4 sm:pt-8 pb-4 sm:pb-6 overflow-hidden">
    <Showcase client:visible />
    <div data-install class="shrink-0 w-full max-w-xl mx-auto px-4">
      <InstallCard client:visible />
    </div>
  </main>
</BaseLayout>
