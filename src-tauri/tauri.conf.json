{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tomat",
  "version": "0.1.0",
  "identifier": "au.tomat.ing",
  "build": {
    "beforeDevCommand": "bun run dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:vite",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "tomat",
        "width": 700,
        "height": 1200,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' http://127.0.0.1:* http://localhost:*; worker-src 'self' blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/tomat-tools-server",
      "binaries/tomat-llama-server",
      "binaries/tomat-whisper-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/server.js",
      "resources/runtime.js",
      "resources/node_modules/**/*",
      "resources/toolkits/**/*",
      "binaries/**/*.dylib",
      "binaries/**/*.so",
      "binaries/**/*.dll"
    ]
  }
}
